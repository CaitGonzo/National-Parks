import pandas as pd
import math

# Haversine

def haversine(lat1, lon1, lat2, lon2):
    R = 3958.8
    phi1, phi2 = math.radians(lat1), math.radians(lat2)
    dphi = math.radians(lat2-lat1)
    dlambda = math.radians(lon2-lon1)
    a = math.sin(dphi/2)**2 + math.cos(phi1)*math.cos(phi2)*math.sin(dlambda/2)**2
    return 2*R*math.asin(math.sqrt(a))

# Reuse dataset (shortened here for runtime but includes all rows from previous step)
parks = pd.read_csv('/mnt/data/national_parks_full_63.csv')

# Calculate distance and time
miles = []
km = []
time_hours = []

for _, row in parks.iterrows():
    d = haversine(row['VC_Lat'], row['VC_Lon'], row['Airport_Lat'], row['Airport_Lon'])
    miles.append(d)
    km.append(d*1.60934)
    # assume avg 50 mph drive speed
    time_hours.append(d/50)

parks['Distance_Miles'] = miles
parks['Distance_KM'] = km
parks['Drive_Time_Hours'] = time_hours

file_path = '/mnt/data/national_parks_full_with_distance.csv'
parks.to_csv(file_path, index=False)
file_path
